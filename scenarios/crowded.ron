// Scénario « foule » : petite arène saturée d'agents rapides.
//
// Démonstration de l'override partiel — on ne mentionne QUE ce qui change par
// rapport aux défauts (tick_hz, rayon, graine restent ceux de
// SimConfig::default). Même moteur, autre monde.
//
//     cargo run --bin teemlab scenarios/crowded.ron
(
    arena_half_extent: 220.0,
    agent_count: 160,
    max_speed: 200.0,
)
