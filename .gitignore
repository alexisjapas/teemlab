/target
/.direnv
*.rs.bk
.DS_Store

# Scratch file written by default from the editor (Save).
/scenarios/edited.ron

# Run snapshot written by default from the Runs panel (Save the run).
/run.ron

# Simulation outputs (videos, images…) written by the `record` recorder and the
# Recording panel. We version the directory (.gitkeep), not its contents.
/outputs/*
!/outputs/.gitkeep

# Font source packages (Inter ~60 MB, Departure Mono) dropped under assets/fonts/:
# we version only the flat static files we load (Inter-Regular.ttf,
# DepartureMono-Regular.otf, Phosphor.ttf), not the whole upstream archives.
/assets/fonts/Inter/
/assets/fonts/DepartureMono/
