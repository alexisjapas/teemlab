/target
/.direnv
*.rs.bk
.DS_Store

# mdBook build output (the docs site is built by CI from docs/src/; the rendered
# HTML is published to GitHub Pages, never committed).
/docs/book

# User-saved scenarios: only the curated `scenarios/examples/` are committed; the
# editor's Save / Save As write here. We keep the directory (.gitkeep), not its files.
/scenarios/saved/*
!/scenarios/saved/.gitkeep

# Archetype libraries: only the curated `species/examples/` library is committed;
# every other library (e.g. `species/saved/` — evolved variants) stays local.
/species/*
!/species/examples/

# Run snapshot written by default from the Runs panel (Save the run).
/run.ron

# Simulation outputs (videos, images…) written by the `record` recorder and the
# Recording panel. We version the directory (.gitkeep), not its contents.
/outputs/*
!/outputs/.gitkeep

# Font source packages (Inter ~60 MB, Departure Mono) dropped under assets/fonts/:
# we version only the flat static files we load (Inter-Regular.ttf,
# DepartureMono-Regular.otf, Phosphor.ttf), not the whole upstream archives.
/assets/fonts/Inter/
/assets/fonts/DepartureMono/
/THIRD-PARTY-LICENSES.html
