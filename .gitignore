/target
/.direnv
*.rs.bk
.DS_Store

# Fichier scratch écrit par défaut depuis l'éditeur (Sauver).
/scenarios/edited.ron

# Snapshot de run écrit par défaut depuis le panneau Runs (Sauver la run).
/run.ron

# Sorties des simulations (vidéos, images…) écrites par l'enregistreur `record`
# et le panneau Enregistrement. On versionne le dossier (.gitkeep), pas son contenu.
/outputs/*
!/outputs/.gitkeep
